# Copy this file to .env, then replace every placeholder with your own value.
# Never commit the resulting .env file.

# IQ Option MCP connection (required)
MCP_URL=https://digital-options.mcp.iqoption.com
MCP_TOKEN=Bearer REPLACE_WITH_YOUR_MCP_TOKEN

# LLM confirmation service (required when LLM confirmation is enabled)
LLM_BASE_URL=https://9router.irobotsonline.com/v1
LLM_MODEL=mimo-text
LLM_API_KEY=REPLACE_WITH_YOUR_LLM_API_KEY

# Account and order settings
ACCOUNT_TYPE=demo
BALANCE_ID=REPLACE_WITH_YOUR_BALANCE_ID
BASE_AMOUNT=30
MG_MULTIPLIER=2.0
MAX_MG_LEVEL=5

# Optional legacy IQ Option credentials used by config/settings.py
IQ_EMAIL=you@example.com
IQ_PASSWORD=REPLACE_WITH_YOUR_IQ_PASSWORD
IQ_BALANCE_TYPE=PRACTICE

# Logging
LOG_LEVEL=INFO
